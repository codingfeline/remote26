// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique @map("session_token")
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  name           String?
  email          String?   @unique
  emailVerified  DateTime? @map("email_verified")
  hashedPassword String?
  image          String?
  accounts       Account[]
  sessions       Session[]

  @@map("users")
}

model VerificationToken {
  identifier String   @id @map("_id")
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// prisma/schema.prisma
model CookieConsent {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String?
  anonymousId   String?  @unique
  analytics     Boolean
  externalMedia Boolean
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model Customer {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  solution String
  date     DateTime
  version  Int      @map("__v")

  methodInfo     MethodInfo[]
  contact        Contact[]
  server         Server[]
  devicePassword DevicePassword[]
  solutionSetup  SolutionSetup[]
  deviceSetup    DeviceSetup[]
  scanToEmail    ScanToEmail[]
  scanToFolder   ScanToFolder[]
}

type MethodInfo {
  id         String @map("_id") @db.ObjectId
  methodName String
  url        String
  username   String
  password   String
  notes      String
}

type Contact {
  id    String @map("_id") @db.ObjectId
  name  String
  tel   String
  email String
}

type Server {
  id       String  @map("_id") @db.ObjectId
  name     String
  username String
  password String
  ip       String
  notes    String?
}

type DevicePassword {
  id       String @map("_id") @db.ObjectId
  make     String
  username String
  password String
}

type SolutionSetup {
  id         String @map("_id") @db.ObjectId
  comment    String
  screenshot String
  path       String
}

type DeviceSetup {
  id         String @map("_id") @db.ObjectId
  comment    String
  screenshot String
  path       String
}

type ScanToEmail {
  id       String @map("_id") @db.ObjectId
  hostname String
  username String
  password String
  port     String
}

type ScanToFolder {
  id       String  @map("_id") @db.ObjectId
  hostname String
  folder   String?
  username String
  password String
}
